# Copy to .env.local for local development against the real backend.
# None of these are required to run the frontend — see .env.example and
# README.md for the mock-data fallback behaviour when they're unset.

# Base URL of the Rust/Axum backend (see backend/.env.example).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Set to "true" to force the dashboard to use client-side mock data even
# when a backend is configured/reachable — this is what the deployed Vercel
# demo uses, since no backend is hosted alongside it.
NEXT_PUBLIC_USE_MOCK_DATA=false

# Demo-only login used to authenticate against the real backend's
# auth-gated dashboard endpoints (this dashboard has no login screen of its
# own in v0.1). Must match a seeded user with role "compliance" or "admin" —
# see backend/src/bin/seed.rs. Defaults below match the seed script's output.
NEXT_PUBLIC_DEMO_EMAIL=compliance@lango.demo
NEXT_PUBLIC_DEMO_PASSWORD=LangoDemo123!
