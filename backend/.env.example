# Copy to backend/.env for local development. Matches docker-compose.yml's
# default credentials — change these before ever running against real data.

DATABASE_URL=postgres://lango:lango_dev_password@localhost:5432/lango

# Any long random string works for local dev. Generate a real one for
# anything beyond a local machine, e.g.: openssl rand -hex 32
JWT_SIGNING_SECRET=dev-only-secret-change-me-before-any-real-deployment

PORT=8080

# Must match the origin the Next.js frontend is actually served from.
CORS_ORIGIN=http://localhost:3000
