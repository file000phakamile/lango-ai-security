# ---------------------------------------------------------------------------
# Lango — AI Data Guard
#
# This file is the LEGACY/ASPIRATIONAL one for a hosted PRODUCTION deployment
# — most of the variables below (AI provider key, alert webhook) are still
# placeholders for future work; nothing in this repo reads them today.
#
# For actually running the real v0.1 backend and frontend locally, use the
# two files this repo's code DOES read:
#   - backend/.env.example   -> copy to backend/.env   (DATABASE_URL, JWT_SIGNING_SECRET, PORT, CORS_ORIGIN)
#   - .env.local.example     -> copy to .env.local      (NEXT_PUBLIC_API_BASE_URL, NEXT_PUBLIC_USE_MOCK_DATA, demo login)
# See README.md's Setup section for the full walkthrough.
# ---------------------------------------------------------------------------

# --- Database (target production backend) -----------------------------------
# PostgreSQL connection string for the audit log, pilot config, and user store.
DATABASE_URL=postgres://lango_user:changeme@localhost:5432/lango

# --- Authentication (target production backend) ------------------------------
# Secret used to sign JWT session tokens. Generate a long random value; never
# commit a real one.
JWT_SIGNING_SECRET=replace-with-a-long-random-secret

# Argon2 parameters for password hashing (defaults shown; tune per deployment).
ARGON2_MEMORY_COST_KB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# --- AI provider connector (target production backend) -----------------------
# API key for whichever AI provider the sanitised prompt is forwarded to after
# passing the Redaction Engine. Never store this in the frontend or commit it.
AI_PROVIDER_API_KEY=replace-with-provider-api-key
AI_PROVIDER_BASE_URL=https://api.example-provider.com/v1

# --- Audit / monitoring (target production backend) ---------------------------
# Where drift-monitor and security-event alerts are sent (e.g. an ops channel
# webhook or paging integration).
ALERT_WEBHOOK_URL=https://hooks.example.com/lango-alerts

# --- Deployment (target production backend) -----------------------------------
NODE_ENV=production
PORT=8080
