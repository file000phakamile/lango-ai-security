{
  "manifest_version": 3,
  "name": "Lango — AI Data Guard",
  "version": "0.4.0",
  "description": "Scans AI chat prompts AND responses for sensitive entities (national IDs, bank accounts, phone numbers, leaked secrets, etc.) and redacts or blocks before sending, or warns after receiving. Response scanning covers chatgpt.com, claude.ai, and gemini.google.com; chat.deepseek.com and copilot.microsoft.com remain prompt-scanning only. See extension/README.md for per-site verification status.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://copilot.microsoft.com/*",
    "https://lango-backend-qwkx.onrender.com/*",
    "http://localhost:8080/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": [
        "content/ui-banner.js",
        "content/site-adapter.js",
        "content/response-scanner.js",
        "content/chatgpt-adapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": [
        "content/ui-banner.js",
        "content/site-adapter.js",
        "content/response-scanner.js",
        "content/claude-adapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "content/ui-banner.js",
        "content/site-adapter.js",
        "content/response-scanner.js",
        "content/gemini-adapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": [
        "content/ui-banner.js",
        "content/site-adapter.js",
        "content/deepseek-adapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://copilot.microsoft.com/*"],
      "js": [
        "content/ui-banner.js",
        "content/site-adapter.js",
        "content/copilot-adapter.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
